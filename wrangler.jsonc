/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "forminator-sync",
	"main": "src/index.js",
	"compatibility_date": "2025-07-30",
	"compatibility_flags": ["nodejs_compat"],
	"preview_urls": false,
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "MAPPINGS_KV",
			"id": "04e4118b842b48a58f5777e008931026",
			"remote": true
		}
	],
	// R2_ASSETS = R2 bucket binding voor de asset_manager module
	// ASSETS (hieronder) = static files binding voor de /public/ map
	// Dit zijn twee verschillende bindings met twee verschillende namen — geen conflict
	"r2_buckets": [
		{
			"binding": "R2_ASSETS",
			"bucket_name": "openvme-assets",
			"remote": true
			// remote: true = echte bucket in zowel wrangler dev als wrangler deploy
			// Geen preview_bucket_name — geen aparte dev-bucket
		}
	],
	"assets": {
		"directory": "./public",
		"binding": "ASSETS"
	},
	"triggers": {
		// "*/15 * * * *"  -> bestaande 15-min jobs (cx_powerboard, cx_automations, mini-apps geplande taken)
		// "*/5 * * * *"   -> NIEUW, apart: mini-apps criteria-taken (condition-scheduler.js), bewust sneller
		"crons": ["*/15 * * * *", "*/5 * * * *"]
	},
	"vars": {
		// Public-facing base URL — used when generating Claude project instructions
		// from a local dev environment so that the instructions always point to production.
		"APP_BASE_URL": "https://forminator-sync.openvme-odoo.workers.dev",
		// Mini-apps AI (window.platform.ai.ask(), zie src/modules/mini-apps/lib/ai.js) —
		// GEMINI_API_KEY zelf is een secret (wrangler secret put), NIET hier.
		"AI_PROVIDER": "gemini",
		"GEMINI_MODEL": "gemini-2.5-flash"
	}
}