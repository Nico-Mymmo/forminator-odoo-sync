# Odoo Configuration
DB_NAME=your-odoo-database
UID=your-user-id
API_KEY=your-odoo-api-key

# WordPress Configuration
WP_USERNAME=your-wp-username
WP_PASSWORD=your-wp-app-password

# Auth Configuration
AUTH_TOKEN=your-bearer-token

# Mini-apps — AI (window.platform.ai.ask(), zie src/modules/mini-apps/lib/ai.js)
# GEMINI_API_KEY: Google AI Studio key voor de gratis laag van de Gemini API
# (LOS van een Google Workspace-abonnement -- zie lib/ai-providers/gemini.js).
# In productie via `wrangler secret put GEMINI_API_KEY`, nooit hier invullen.
GEMINI_API_KEY=your-gemini-api-key
