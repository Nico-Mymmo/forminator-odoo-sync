# Local development environment variables
# Copy this file to .dev.vars and fill in your values

# Odoo Configuration
DB_NAME=mymmo-main-11883993
UID=2
API_KEY=c6c225cd1740456eb974abe3a5b18d016d12b2c4

# Supabase (history logging)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Authentication
AUTH_TOKEN=your_webhook_auth_token_here
ADMIN_TOKEN=your_admin_password_here

# WordPress (optional - for WordPress API access)
WP_USERNAME=your_wp_username
WP_PASSWORD=your_wp_app_password

# Google Workspace (mail-signature-designer)
# Volledige service account JSON op één regel — roteer via Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Mini-apps — notify (optioneel, zie src/modules/mini-apps/lib/gmail-send-client.js)
# IMPERSONATE = de echte mailbox die we domain-wide impersoneren (moet bestaan).
# FROM = het adres dat de ontvanger ziet -- mag een alternatief e-mailadres/alias
# van IMPERSONATE zijn (bv. hallo-collega@mymmo.com), voeg dat eerst toe via
# Admin Console -> Directory -> Gebruikers -> alternatief e-mailadres.
# Beide default naar nico@mymmo.com als je ze weglaat.
MINI_APPS_NOTIFY_IMPERSONATE_EMAIL=nico@mymmo.com
MINI_APPS_NOTIFY_FROM_EMAIL=hallo-collega@mymmo.com
