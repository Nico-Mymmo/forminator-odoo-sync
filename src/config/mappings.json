{
    "_comment": "Forminator form mappings to Odoo - Edit this file to add/update form configurations",
    "_documentation": "See README.md for full documentation on workflow syntax and field mapping",
    "11987": {
        "field_mapping": {
            "name_1_first_name": "first_name",
            "name_1_last_name": "last_name",
            "email_1": "email",
            "phone_1": "phone",
            "text_1": "street",
            "text_2": "number",
            "number_1": "zip",
            "slider_1": "number_of_units",
            "text_3": "city",
            "radio_1": "ownership_type",
            "form_title": "form_title",
            "entry_time": "entry_time"
        },
        "value_mapping": {
            "ownership_type": {
                "no-syndic": "",
                "co-owner-syndic-neighbour": "",
                "co-owner-syndic-me": "",
                "professional-syndic": "",
                "_default": "",
                "_comment": "Use _default for unmapped values, or _skip: true to remove field"
            }
        },
        "workflow": [
            {
                "step": "contact",
                "model": "res.partner",
                "search": {
                    "domain": [
                        [
                            "email",
                            "=",
                            "${email}"
                        ]
                    ],
                    "fields": [
                        "id",
                        "name",
                        "email"
                    ]
                },
                "create": {
                    "email": "${email}",
                    "name": "${first_name} ${last_name}",
                    "mobile": "${phone}",
                    "street": "${street} ${number}",
                    "zip": "${zip}",
                    "city": "${city}",
                    "country_id": 20,
                    "x_studio_contact_type": "9",
                    "x_studio_company_type": 1,
                    "lang": "nl_BE",
                    "x_studio_selection_field_3l2_1hnli05jb": "Opportunity"
                }
            },
            {
                "step": "company",
                "model": "res.partner",
                "search": {
                    "domain": [
                        [
                            "id",
                            "=",
                            "$contact.parent_id"
                        ]
                    ],
                    "fields": [
                        "id",
                        "name",
                        "is_company"
                    ]
                }
            }
        ]
    },
    "_example_complex": {
        "field_mapping": {
            "name-1": "full_name",
            "email-3": "email_address",
            "text_1": "company",
            "textarea_5": "notes",
            "radio-5": "priority"
        },
        "value_mapping": {
            "priority": {
                "low": "1",
                "medium": "2",
                "high": "3",
                "_default": "2",
                "_comment": "Unknown priority defaults to medium (2)"
            },
            "status": {
                "active": "active",
                "inactive": "inactive",
                "_skip": true,
                "_comment": "Remove status field if value not recognized"
            }
        },
        "workflow": [
            {
                "step": "contact",
                "model": "res.partner",
                "search": {
                    "domain": [
                        [
                            "email",
                            "=",
                            "${email_address}"
                        ]
                    ],
                    "fields": [
                        "id",
                        "name",
                        "email",
                        "parent_id"
                    ]
                },
                "create": {
                    "email": "${email_address}",
                    "name": "${full_name}",
                    "phone": "${phone}"
                }
            },
            {
                "_comment": "Check if contact has a company, if not create one",
                "step": "company",
                "model": "res.partner",
                "search": {
                    "domain": [
                        [
                            "id",
                            "=",
                            "$contact.parent_id"
                        ]
                    ],
                    "fields": [
                        "id",
                        "name",
                        "is_company"
                    ]
                },
                "create": {
                    "name": "${company}",
                    "is_company": true
                }
            },
            {
                "_comment": "Link contact to company if needed",
                "step": "link_contact",
                "model": "res.partner",
                "search": {
                    "domain": [
                        [
                            "id",
                            "=",
                            "$contact.id"
                        ]
                    ],
                    "fields": [
                        "id"
                    ]
                },
                "update": {
                    "parent_id": "$company.id"
                }
            },
            {
                "step": "lead",
                "model": "crm.lead",
                "search": {
                    "domain": [
                        [
                            "partner_id",
                            "=",
                            "$contact.id"
                        ],
                        [
                            "type",
                            "=",
                            "opportunity"
                        ]
                    ],
                    "fields": [
                        "id",
                        "name",
                        "partner_id"
                    ]
                },
                "create": {
                    "name": "Lead voor ${full_name} - ${entry_time}",
                    "partner_id": "$contact.id",
                    "email_from": "${email_address}",
                    "phone": "${phone}",
                    "description": "${notes}"
                },
                "update": {
                    "enabled": true,
                    "fields": {
                        "description": "${notes}"
                    }
                }
            },
            {
                "step": "update_existing_record",
                "model": "some.model",
                "search": {
                    "domain": [
                        [
                            "partner_id",
                            "=",
                            "$contact.id"
                        ]
                    ],
                    "fields": [
                        "id",
                        "name"
                    ]
                },
                "update": {
                    "enabled": true,
                    "fields": {
                        "last_updated": "${entry_time}",
                        "notes": "${notes}"
                    }
                }
            }
        ]
    }
}