<form string="Partners">
  <header>
    <field name="x_studio_stage_id" widget="statusbar" options="{'clickable': '1'}"/>
  </header>
  <sheet>
    <div class="oe_button_box" name="button_box"/>
    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
    <field name="avatar_128" invisible="1"/>
    <field name="x_active" invisible="1"/>
    <div class="oe_title">
      <h1>
        <field name="x_name" placeholder="Name"/>
      </h1>
    </div>
    <group name="studio_group_b18b1a">
      <group name="studio_group_b18b1a_left">
        <field name="x_studio_user_id" widget="many2one_avatar_user"/>
        <field name="x_studio_tag_ids" widget="many2many_tags"/>
      </group>
      <group name="studio_group_b18b1a_right">
        <field name="x_studio_phone"/>
        <field name="x_studio_email"/>
      </group>
    </group>
    <group name="studio_group_extra">
      <group name="studio_group_extra_left"/>
      <group name="studio_group_extra_right"/>
    </group>
  </sheet>
</form>
